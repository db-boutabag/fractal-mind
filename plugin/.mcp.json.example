{
  "mcpServers": {
    "obsidian": {
      "command": "uvx",
      "args": ["mcp-obsidian"],
      "env": {
        "OBSIDIAN_API_KEY": "$OBSIDIAN_API_KEY"
      }
    },
    "google-workspace": {
      "command": "uvx",
      "args": ["workspace-mcp", "--tools", "drive", "docs", "--read-only"],
      "env": {
        "GOOGLE_OAUTH_CLIENT_ID": "$GOOGLE_OAUTH_CLIENT_ID",
        "GOOGLE_OAUTH_CLIENT_SECRET": "$GOOGLE_OAUTH_CLIENT_SECRET"
      }
    }
  }
}
